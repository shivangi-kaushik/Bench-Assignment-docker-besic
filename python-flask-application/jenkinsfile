pipeline {
    agent any

    environment {
        IMAGE_NAME = "shivangikaushik/flask-web-app"
        IMAGE_TAG  = "latest"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'feature/docker-basic',
                url: 'https://github.com/shivangi-kaushik/Bench-Assignment-docker-besic.git'
            }
        }

        stage('Build Docker Image') {
            steps {

                dir('python-flask-application') {

                    sh 'ls -la'

                    sh 'docker build -t flask-web-app:latest .'
                }
            }
        }

        stage('Push Docker Image') {
            steps {

                withCredentials([usernamePassword(
                    credentialsId: 'docker-creds',
                    usernameVariable: 'DOCKERHUB_USERNAME',
                    passwordVariable: 'DOCKERHUB_PASSWORD'
                )]) {

                    sh '''
                    echo "$DOCKERHUB_PASSWORD" | docker login -u "$DOCKERHUB_USERNAME" --password-stdin

                    docker tag flask-web-app:latest $IMAGE_NAME:$IMAGE_TAG

                    docker push $IMAGE_NAME:$IMAGE_TAG
                    '''
                }
            }
        }

        stage('Deploy Container') {
            steps {

                sh '''
                docker stop flask-container || true

                docker rm flask-container || true

                docker run -d \
                --name flask-container \
                -p 5000:5000 \
                $IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }
    }

    post {

        success {
            echo 'Pipeline executed successfully'
        }

        failure {
            echo 'Pipeline failed'
        }
    }
}