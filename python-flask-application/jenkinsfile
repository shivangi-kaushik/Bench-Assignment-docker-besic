pipeline {

    // Run pipeline on any available Jenkins agent
    agent any

    // Global environment variables
    environment {

        // Docker image repository name
        IMAGE_NAME = "shivangikaushik/flask-web-app"

        // Docker image tag/version
        IMAGE_TAG  = "latest"
    }

    stages {

        // =========================================
        // Stage 1 : Checkout Source Code from GitHub
        // =========================================
        stage('Checkout') {

            steps {

                // Clone repository from GitHub branch
                git branch: 'feature/docker-basic',
                url: 'https://github.com/shivangi-kaushik/Bench-Assignment-docker-besic.git'
            }
        }

        // =========================================
        // Stage 2 : Build Docker Image
        // =========================================
        stage('Build Docker Image') {

            steps {

                // Move inside application directory
                dir('python-flask-application') {

                    // List all files for debugging/verification
                    sh 'ls -la'

                    // Build Docker image using Dockerfile
                    sh 'docker build -t flask-web-app:latest .'
                }
            }
        }

        // =========================================
        // Stage 3 : Push Docker Image to Docker Hub
        // =========================================
        stage('Push Docker Image') {

            steps {

                // Fetch Docker Hub credentials securely from Jenkins
                withCredentials([usernamePassword(

                    // Jenkins credentials ID
                    credentialsId: 'docker-creds',

                    // Store Docker username in variable
                    usernameVariable: 'DOCKERHUB_USERNAME',

                    // Store Docker password/token in variable
                    passwordVariable: 'DOCKERHUB_PASSWORD'
                )]) {

                    sh '''

                    # Login to Docker Hub securely
                    echo "$DOCKERHUB_PASSWORD" | docker login -u "$DOCKERHUB_USERNAME" --password-stdin

                    # Tag local Docker image with Docker Hub repository name
                    docker tag flask-web-app:latest $IMAGE_NAME:$IMAGE_TAG

                    # Push Docker image to Docker Hub
                    docker push $IMAGE_NAME:$IMAGE_TAG
                    '''
                }
            }
        }

        // =========================================
        // Stage 4 : Deploy Docker Container
        // =========================================
        stage('Deploy Container') {

            steps {

                sh '''

                # Stop existing container if already running
                docker stop flask-container || true

                # Remove old container if exists
                docker rm flask-container || true

                # Run new container from latest Docker image
                docker run -d \
                --name flask-container \
                -p 5003:5000 \
                $IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }
    }

    // =========================================
    // Post Build Actions
    // =========================================
    post {

        // Executes when pipeline succeeds
        success {

            echo 'Pipeline executed successfully'
        }

        // Executes when pipeline fails
        failure {

            echo 'Pipeline failed'
        }
    }
}